{
  "name": "quanta",
  "version": "0.1.0",
  "description": "Quanta CLI - AI-powered quantitative trading system with real-time decision making",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "quanta": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "quanta",
    "ai-trading",
    "quantitative",
    "cryptocurrency",
    "binance",
    "openrouter",
    "deepseek",
    "trading-bot",
    "ai-quant",
    "quantitative-trading"
  ],
  "author": "Quanta CLI",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "ccxt": "^4.2.25",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "ink": "^4.4.1",
    "ora": "^7.0.1",
    "react": "^18.2.0",
    "technicalindicators": "^3.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.42",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.6.2",
    "tsx": "^4.6.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
