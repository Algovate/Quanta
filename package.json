{
  "name": "quanta",
  "version": "0.1.0",
  "description": "Quanta - AI-powered quantitative trading system with real-time decision making",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "quanta": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "type-check:strict": "tsc -p tsconfig.strict.json --noEmit",
    "web:dev": "cd web && npm run dev",
    "web:build": "cd web && npm run build",
    "api:dev": "tsx src/web/start-server.ts",
    "dev:all": "npm run api:dev & npm run web:dev",
    "test:okx:ticker": "tsx tests/okx/ticker.ts",
    "test:okx:unit": "tsx tests/okx/okx.unit.ts"
  },
  "keywords": [
    "quanta",
    "ai-trading",
    "quantitative",
    "cryptocurrency",
    "binance",
    "openrouter",
    "deepseek",
    "trading-bot",
    "ai-quant",
    "quantitative-trading"
  ],
  "author": "Quanta CLI",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "ccxt": "^4.2.25",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "commander": "^11.1.0",
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.3.1",
    "express": "^5.1.0",
    "ora": "^7.0.1",
    "technicalindicators": "^3.1.0",
    "ws": "^8.18.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/cors": "^2.8.19",
    "@types/ws": "^8.18.1",
    "@eslint/js": "^9.38.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.6.2",
    "tsx": "^4.6.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
